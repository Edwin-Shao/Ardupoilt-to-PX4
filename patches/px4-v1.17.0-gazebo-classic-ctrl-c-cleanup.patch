 SIM_PID=0
+GUI_PID=0
+
+cleanup_sim()
+{
+	local pid
+
+	for pid in ${SIM_PID:-0} ${GUI_PID:-0}; do
+		if [ "$pid" -gt 0 ] 2>/dev/null && kill -0 "$pid" 2>/dev/null; then
+			kill "$pid" 2>/dev/null || true
+		fi
+	done
+
+	sleep 1
+
+	for pid in ${SIM_PID:-0} ${GUI_PID:-0}; do
+		if [ "$pid" -gt 0 ] 2>/dev/null && kill -0 "$pid" 2>/dev/null; then
+			kill -9 "$pid" 2>/dev/null || true
+		fi
+	done
+}
+
+trap cleanup_sim EXIT
+trap 'exit 130' INT
+trap 'exit 143' TERM
 
