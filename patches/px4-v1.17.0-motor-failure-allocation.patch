+void MotorFailureSystem::ApplyYawDrag(EntityComponentManager &_ecm)
+{
+    if (this->_yaw_drag_coefficient <= 0.0 || !this->_base_link.Valid(_ecm)) {
+        return;
+    }
+
+    const auto angular_velocity_world = this->_base_link.WorldAngularVelocity(_ecm);
+    const auto pose_world = this->_base_link.WorldPose(_ecm);
+
+    if (!angular_velocity_world.has_value() || !pose_world.has_value()) {
+        return;
+    }
+
+    const auto body_z_world = pose_world->Rot().RotateVector(math::Vector3d::UnitZ);
+    const double yaw_rate = angular_velocity_world->Dot(body_z_world);
+    const auto drag_torque_world =
+        body_z_world * (-this->_yaw_drag_coefficient * yaw_rate * std::abs(yaw_rate));
+
+    this->_base_link.AddWorldWrench(_ecm, math::Vector3d::Zero, drag_torque_world);
+}
